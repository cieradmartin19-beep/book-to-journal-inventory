# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local development only. Used by the temporary one-time recovery tool.
# Never expose this in client code and do not add it to Vercel.
SUPABASE_SERVICE_ROLE_KEY=

# Enables cover OCR for uploaded cover images.
GOOGLE_CLOUD_VISION_API_KEY=

# Optional. Google Books works without a key at low volume, but a key is better.
GOOGLE_BOOKS_API_KEY=
